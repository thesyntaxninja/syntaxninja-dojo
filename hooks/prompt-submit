#!/bin/bash
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
PLUGIN_ROOT="$(dirname "$SCRIPT_DIR")"

VERSION=$(jq -r '.version // "0.1.0"' "$PLUGIN_ROOT/.claude-plugin/plugin.json" 2>/dev/null || echo "0.1.0")

# Compute index hashes
SKILLS_HASH="none"
PATTERNS_HASH="none"
if [ -f "$PLUGIN_ROOT/skills/index.json" ]; then
    SKILLS_HASH=$(shasum -a 256 "$PLUGIN_ROOT/skills/index.json" 2>/dev/null | cut -d' ' -f1 || echo "none")
fi
if [ -f "$PLUGIN_ROOT/patterns/index.json" ]; then
    PATTERNS_HASH=$(shasum -a 256 "$PLUGIN_ROOT/patterns/index.json" 2>/dev/null | cut -d' ' -f1 || echo "none")
fi

# Detect project config (repo root first, then .claude/ fallback)
PROJECT_CONFIG="none"
if [ -f "dojo.config.md" ]; then
    PROJECT_CONFIG="dojo.config.md"
elif [ -f ".claude/dojo-config.md" ]; then
    PROJECT_CONFIG=".claude/dojo-config.md"
fi

# Dual fingerprint for interop
REMINDER="PLUGIN_ROUTER: syntaxninja-dojo@${VERSION}
DOJO_ROUTER: syntaxninja-dojo@${VERSION}
REMINDER: Before responding, consult skills/index.json. Load 1-3 matching skills via Skill tool. If no match, gate skills influence behavior silently.
GATES: verification-before-completion (on completion claims), self-review (after implementation), systematic-debugging (on error), scope-control (silent always)
SKILLS_HASH: ${SKILLS_HASH}
PATTERNS_HASH: ${PATTERNS_HASH}
CONFIG: ${PROJECT_CONFIG}"

# Uses jq to properly escape content for valid JSON
jq -n --arg ctx "$REMINDER" '{
  hookSpecificOutput: { additionalContext: $ctx }
}'
