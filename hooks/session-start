#!/usr/bin/env bash
# SessionStart hook for syntaxninja-dojo plugin

set -euo pipefail

# Determine plugin root directory
SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]:-$0}")" && pwd)"
PLUGIN_ROOT="$(cd "${SCRIPT_DIR}/.." && pwd)"

CHARTER_FILE="$PLUGIN_ROOT/skills/_charter/SKILL.md"

if [ ! -f "$CHARTER_FILE" ]; then
    echo '{"error": "Dojo Charter not found at '"$CHARTER_FILE"'"}'
    exit 1
fi

CHARTER_CONTENT=$(cat "$CHARTER_FILE")

VERSION=$(jq -r '.version // "0.1.0"' "$PLUGIN_ROOT/.claude-plugin/plugin.json" 2>/dev/null || echo "0.1.0")

# Detect project config
PROJECT_CONFIG="none"
if [ -f "dojo.config.md" ]; then
    PROJECT_CONFIG="dojo.config.md"
elif [ -f ".claude/dojo-config.md" ]; then
    PROJECT_CONFIG=".claude/dojo-config.md"
fi

# Escape string for JSON embedding using bash parameter substitution.
escape_for_json() {
    local s="$1"
    s="${s//\\/\\\\}"
    s="${s//\"/\\\"}"
    s="${s//$'\n'/\\n}"
    s="${s//$'\r'/\\r}"
    s="${s//$'\t'/\\t}"
    printf '%s' "$s"
}

# Build the additional context payload
CONTEXT="PLUGIN_ROUTER: syntaxninja-dojo@${VERSION}
DOJO_ROUTER: syntaxninja-dojo@${VERSION}

You have the SyntaxNinja Dojo plugin installed.

**Below is the full content of the Dojo Charter — your guide to using skills. For all other skills, use the Skill tool:**

---
${CHARTER_CONTENT}

---

SKILL_INDEX: ${PLUGIN_ROOT}/skills/index.json
PATTERN_INDEX: ${PLUGIN_ROOT}/patterns/index.json
PROJECT_CONFIG: ${PROJECT_CONFIG}"

session_context=$(escape_for_json "$CONTEXT")

# Output context injection as JSON.
# Keep both shapes for compatibility:
# - Cursor hooks expect additional_context.
# - Claude hooks expect hookSpecificOutput.additionalContext.
cat <<EOF
{
  "additional_context": "${session_context}",
  "hookSpecificOutput": {
    "hookEventName": "SessionStart",
    "additionalContext": "${session_context}"
  }
}
EOF

exit 0
